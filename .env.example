# ═══════════════════════════════════════════════════════════════
# ClawBot Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in required values:
#   cp .env.example .env
#
# Or run the interactive setup:
#   make setup
# ═══════════════════════════════════════════════════════════════

# ── Required ──────────────────────────────────────────────────

# Anthropic API key (get one at https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Optional (defaults shown) ────────────────────────────────

# Gateway WebSocket port exposed to host
# GATEWAY_PORT=8080

# Browser CDP authentication token
# BROWSER_TOKEN=clawbot-dev

# SearXNG search endpoint (internal Docker network)
# CLAWBOT_SEARXNG_URL=http://searxng:8080

# Gateway WebSocket URL (internal Docker network, used by agent)
# CLAWBOT_GATEWAY_URL=ws://gateway:8080

# Agent workspace mount point
# CLAWBOT_WORKSPACE=/workspace

# Chrome browser profile storage
# BROWSER_PROFILES_DIR=/data/browser-profiles

# Claude model override
# CLAWBOT_MODEL=claude-sonnet-4-5-20250929

# Agent max iterations per turn (1-100)
# CLAWBOT_MAX_ITERATIONS=25

# ── Optional: OpenRouter fallback ────────────────────────────

# If set, agent cascades through cheaper models when Anthropic API is down
# OPENROUTER_API_KEY=sk-or-v1-your-key-here

# ── Optional: SerpAPI (alternative to SearXNG) ──────────────

# If set, uses SerpAPI instead of self-hosted SearXNG for web search
# CLAWBOT_CRED_SERPAPI=your-serpapi-key
